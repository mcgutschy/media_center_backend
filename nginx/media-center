    server {
        server_name media.b481.de;

        add_header X-Frame-Options "SAMEORIGIN" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-XSS-Protection "1; mode=block" always;

        client_max_body_size 2G;

        
        # Demo Panel (PHP)
        location /demo/ {
            alias /var/www/media-demo/;
            index index.php login.php;
            try_files $uri $uri/ /demo/login.php;

            location ~ /demo/(.+\.php)$ {
                fastcgi_pass unix:/run/php/php8.4-fpm.sock;
                fastcgi_param SCRIPT_FILENAME /var/www/media-demo/$1;
                include fastcgi_params;
            }
        }

        # Admin Panel (PHP)
        location /admin/ {
            alias /var/www/media-admin/;
            index index.php login.php;
            try_files $uri $uri/ /admin/login.php;

            location ~ /admin/(.+\.php)$ {
                fastcgi_pass unix:/run/php/php8.4-fpm.sock;
                fastcgi_param SCRIPT_FILENAME /var/www/media-admin/$1;
                include fastcgi_params;
            }
        }

location / {
            proxy_pass http://127.0.0.1:8080;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
            proxy_read_timeout 600s;
            proxy_send_timeout 600s;
        }

        access_log /var/log/nginx/media-center.access.log;
        error_log /var/log/nginx/media-center.error.log;
    
    listen [::]:443 ssl ipv6only=on; # managed by Certbot
    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/media.b481.de/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/media.b481.de/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot


    add_header Strict-Transport-Security "max-age=31536000" always; # managed by Certbot


    ssl_trusted_certificate /etc/letsencrypt/live/media.b481.de/chain.pem; # managed by Certbot
    ssl_stapling on; # managed by Certbot
    ssl_stapling_verify on; # managed by Certbot

}
